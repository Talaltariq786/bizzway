PORT=8080
# Optional: bind address (default 0.0.0.0 — LAN phone + cloud). Local-only: HOST=127.0.0.1
# HOST=0.0.0.0
# Local: docker compose up -d  →  mongodb://127.0.0.1:27017/bizzway
# Atlas: mongodb+srv://USER:PASS@cluster....mongodb.net/bizzway?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/bizzway

# Har secret kam az kam 16 characters (env validation).
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

CORS_ORIGIN=http://localhost:3000

# Firebase Admin (FCM)
# Option A: inline JSON service account
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Option B: file path to service account JSON
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/serviceAccount.json
#
# Optional: override project id (usually inside service account json)
# FIREBASE_PROJECT_ID=bizzway-9ff88

# —— Public URL (payments / IPN) — set to your real API URL in production (https://...)
# PUBLIC_APP_BASE_URL=https://api.example.com
# PAYMENT_SUCCESS_REDIRECT=bizzway://pay-success
# PAYMENTS_MOCK_SUCCESS=false

# JazzCash (merchant portal → sandbox or live credentials; Integrity = hash key)
# JAZZCASH_SANDBOX=true
# JAZZCASH_MERCHANT_ID=
# JAZZCASH_PASSWORD=
# JAZZCASH_INTEGRITY_SALT=
# JAZZCASH_SKIP_RETURN_HASH_VERIFY=false

# EasyPaisa / Telenor Easypay (field names + merchantHash: match PDF from merchant portal)
# EASYPAY_SANDBOX=true
# EASYPAY_STORE_ID=
# EASYPAY_HASH_KEY=
# EASYPAY_FORM_POST_URL=
# EASYPAY_IPN_SKEY_VALUE=
# EASYPAY_IPN_INSECURE_DEV=false

